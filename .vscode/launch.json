{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug WinForms (.NET Framework)",
      "type": "clr",
      "request": "launch",
      "preLaunchTask": "build-winforms-debug",
      "program": "${workspaceFolder}/bin/Debug/net48/proyectoDelegado-HacerFuncionar.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    },
    {
      "name": "Release WinForms (.NET Framework)",
      "type": "clr",
      "request": "launch",
      "preLaunchTask": "build-winforms-release",
      "program": "${workspaceFolder}/bin/Release/net48/proyectoDelegado-HacerFuncionar.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    }
  ]
}
